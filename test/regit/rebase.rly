(ns regit.tests.rebase
  (:require [regit.rebase :as rebase]
            [regit.status :as status]
            [regit.tests.util :refer [assert-focused-command
                                      assert-focused-commit-comments-dimmed
                                      assert-focused-regit-commit
                                      assert-focused-status
                                      buffer-content
                                      buffer-display-content
                                      cleanup
                                      commit-file!
                                      find-line
                                      focused-buffer
                                      focused-buffer-name
                                      focused-content
                                      focused-display-content
                                      git
                                      git!
                                      git-out
                                      messages-content
                                      minibuffer-ui-content
                                      move-focused-line!
                                      move-focused-line-containing!
                                      send-keys
                                      sh!
                                      status-content
                                      wait-for-focused-status
                                      wait-for-message]]
            [regit.command :as regit-command]
            [relay.base.buffer :as buffer]
            [relay.base.frame :as frame]
            [relay.base.keys :as keys]
            [relay.base.mode :as mode]
            [relay.base.theme :as theme]
            [relay.string :as str]
            [relay.test :as test :refer [deftest is= is-error]]))

(def base-rebase-args
  {:keep-empty false
   :rebase-merges nil
   :update-refs false
   :committer-date-is-author-date false
   :ignore-date false
   :autosquash false
   :autostash false
   :interactive false
   :no-verify false})

(defn- init-rebase-test-repo [name]
  (let [tmp-dir (temp-file-path name)
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (git! tmp-dir "init")
        _ (git! tmp-dir "config" "user.email" "test@example.com")
        _ (git! tmp-dir "config" "user.name" "Test User")
        _ (commit-file! tmp-dir "base.txt" "base\n" "base")
        _ (git! tmp-dir "branch" "-M" "main")
        _ (git! tmp-dir "remote" "add" "origin" tmp-dir)
        _ (git! tmp-dir "update-ref" "refs/remotes/origin/main" "HEAD")
        _ (git! tmp-dir "branch" "--set-upstream-to=origin/main" "main")
        _ (git! tmp-dir "config" "remote.pushDefault" "origin")
        _ (commit-file! tmp-dir "one.txt" "one\n" "one")
        _ (commit-file! tmp-dir "two.txt" "two\n" "two")
        _ (commit-file! tmp-dir "three.txt" "three\n" "three")
        _ (git! tmp-dir "branch" "newbase" "origin/main")
        _ (git! tmp-dir "checkout" "newbase")
        _ (commit-file! tmp-dir "newbase.txt" "newbase\n" "newbase")
        _ (git! tmp-dir "checkout" "main")]
    tmp-dir))

(defn- init-conflicted-rebase-test-repo [name]
  (let [tmp-dir (temp-file-path name)
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (git! tmp-dir "init")
        _ (git! tmp-dir "config" "user.email" "test@example.com")
        _ (git! tmp-dir "config" "user.name" "Test User")
        _ (commit-file! tmp-dir "conflict.txt" "base\n" "base")
        _ (git! tmp-dir "branch" "-M" "main")
        _ (git! tmp-dir "checkout" "-b" "feature")
        _ (commit-file! tmp-dir "conflict.txt" "feature\n" "feature conflict")
        _ (git! tmp-dir "checkout" "main")
        _ (commit-file! tmp-dir "conflict.txt" "main\n" "main conflict")
        _ (git! tmp-dir "checkout" "feature")
        result (git tmp-dir "rebase" "main")]
    (test/assert (not (zero? (:code result))) "rebase should stop with a conflict")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "rebase should be in progress after conflict")
    tmp-dir))

(defn- subject-hash [root subject]
  (git-out root "log" "--format=%H" "--grep" (str "^" subject "$") "-n" "1"))

(defn- log-subjects [root]
  (str/split-lines (git-out root "log" "--format=%s")))

(defn- send-keys-queued [keys-str]
  (let [frame-id (:id *frame*)]
    (frame/set-pending-sequence! frame-id [])
    (frame/set-numeric-prefix! frame-id nil))
  (doseq [keyspec (keys/parse-key-sequence keys-str)]
    (enqueue-key-event-and-wait keyspec)))

(defn- send-text [text]
  (dotimes [idx (count text)]
    (send-keys (str (nth text idx)))))

(defn- last-message []
  (or (last (str/split-lines (buffer-content (buffer/get-buffer "*Messages*"))))
    ""))

(defn- focused-todo-lines []
  (str/split-lines (focused-display-content)))

(defn- focused-line []
  (let [win (focused-window)
        buf (window-buffer win)]
    (with-read-lock [lock (buffer-text buf)]
      (buffer/char-to-line lock (cursor-position win)))))

(defn- focused-todo-line-at [line]
  (nth (focused-todo-lines) line ""))

(defn- assert-focused-log-select [needle context]
  (test/assert (str/includes? (focused-content) needle)
    (str context ": expected log-select text " needle "\ncontent:\n" (focused-content)))
  (test/assert (str/includes? (focused-buffer-name) "regit-log-select")
    (str context ": expected regit-log-select buffer, got " (focused-buffer-name))))

(defn- assert-focused-todo [context]
  (test/assert (str/includes? (focused-buffer-name) "git-rebase-todo")
    (str context ": expected git-rebase-todo buffer, got " (focused-buffer-name)))
  (test/assert (= true (:read-only @(buffer-state (focused-buffer))))
    (str context ": git-rebase-todo buffer should be read-only"))
  (binding [*buffer* (focused-buffer)]
    (is= :git-rebase-todo *mode*)
    (test/assert (contains? (set *submodes*) :vim)
      (str context ": git-rebase-todo buffer should enable vim submode. Current submodes: " *submodes*))))

(defn- assert-focused-todo-action-face [action context]
  (let [buf (focused-buffer)
        line (focused-line)
        start (with-read-lock [lock (buffer-text buf)]
                (buffer/line-to-char lock line))
        end (+ start (count action))
        action-span (first (filter #(and (= start (:start %)) (= end (:end %)))
                             (buffer/property-spans buf)))
        actual-style (when action-span (style->map (:properties action-span)))
        expected-style (style->map (theme/style-for-face :git-rebase-todo-action))]
    (test/assert action-span
      (str context ": expected action span for " action ". Spans: " (buffer/property-spans buf)))
    (is= (:fg expected-style) (:fg actual-style))))

(defn- open-rebase-command-from-status! [root]
  (status/regit-status root)
  (assert-focused-status root "before opening rebase")
  (send-keys "r")
  (assert-focused-command "Rebase main onto" "after pressing r"))

(defn- pick-log-commit! [down-count]
  (dotimes [_ down-count]
    (send-keys "j"))
  (send-keys "C-c C-c"))

(defn- choose-target! [target]
  (case target
    "main" (send-keys "<enter>")
    "newbase" (send-keys "<down> <enter>")
    "origin/main" (send-keys "<down> <down> <enter>")
    (do
      (send-text target)
      (send-keys "<enter>"))))

(deftest run-shell-star-options-env-test
  (let [result (run-shell* "sh" ["-c" "printf %s \"$REGIT_ENV_TEST\""]
                 {:direnv false :env {"REGIT_ENV_TEST" "ok"}})]
    (is= 0 (:code result))
    (is= "ok" (:out result))))

(deftest regit-rebase-args-test
  (is= ["--keep-empty"
        "--rebase-merges=rebase-cousins"
        "--update-refs"
        "--committer-date-is-author-date"
        "--autosquash"
        "--autostash"
        "--interactive"
        "--no-verify"]
    (rebase/rebase-args
      {:keep-empty true
       :rebase-merges "rebase-cousins"
       :update-refs true
       :committer-date-is-author-date true
       :ignore-date false
       :autosquash true
       :autostash true
       :interactive true
       :no-verify true}))
  (is= ["--autostash"] (rebase/rebase-args {}))
  (is= [] (rebase/rebase-args {:autostash false})))

(deftest regit-rebase-ui-and-status-binding-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-ui")]
    (status/regit-status tmp-dir)
    (let [status-key (keys/lookup-keymap status/regit-status-keymap (keys/parse-key-sequence "r"))]
      (test/assert (ifn? status-key) "regit-status did not bind r to rebase"))
    (rebase/regit-rebase tmp-dir)
    (let [ui-win (minibuffer-ui-window)
          ui-buf (window-buffer ui-win)]
      (binding [*buffer* ui-buf
                *window* ui-win
                *mode* :regit-command
                *submodes* #{}]
        (let [text (buffer-content ui-buf)
              st @regit-command/*state*]
          (is= true (get-in st [:args :autostash :value]))
          (test/assert (contains? (:args st) :keep-empty))
          (test/assert (contains? (:args st) :rebase-merges))
          (test/assert (contains? (:args st) :update-refs))
          (test/assert (contains? (:args st) :committer-date-is-author-date))
          (test/assert (contains? (:args st) :ignore-date))
          (test/assert (contains? (:args st) :autosquash))
          (test/assert (contains? (:args st) :interactive))
          (test/assert (contains? (:args st) :no-verify))
          (doseq [key ["p" "u" "e" "i" "s" "m" "w" "k" "f"]]
            (test/assert (contains? (:actions st) key) (str "missing rebase action " key)))
          (test/assert (str/includes? text "Keep empty commits") "missing --keep-empty label")
          (test/assert (str/includes? text "--rebase-merges=") "missing --rebase-merges label")
          (test/assert (str/includes? text "Rebase main onto") "missing branch onto heading")
          (test/assert (str/includes? text "interactively") "missing interactive action")
          (test/assert (str/includes? text "to autosquash") "missing autosquash action"))
        (when-let [close-cmd (regit-command/regit-command-keymap (keys/parse-key-sequence "q"))]
          (close-cmd))))
    (cleanup tmp-dir)))

(deftest regit-rebase-interactive-opens-read-only-todo-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-todo")
        two (subject-hash tmp-dir "two")
        result (rebase/run-rebase-interactive! tmp-dir base-rebase-args two)]
    (test/assert (not (string? result)) (str "interactive rebase failed: " result))
    (let [todo-window (focused-window)
          todo-buffer (window-buffer todo-window)]
      (binding [*buffer* todo-buffer
                *window* todo-window
                *mode* :git-rebase-todo
                *submodes* #{}]
        (is= true (:read-only @(buffer-state todo-buffer)))
        (test/assert (str/includes? (buffer-content todo-buffer) "pick") "todo should contain pick lines")
        (is-error (insert-string "# direct edit should fail"))
        (move-cursor (with-read-lock [lock (buffer-text todo-buffer)]
                       (buffer/line-to-char lock (find-line (buffer-content todo-buffer) "pick ")))
          false
          todo-window)
        (rebase/git-rebase-todo-edit)
        (test/assert (str/includes? (buffer-content todo-buffer) "edit ") "todo edit command should update read-only buffer through override")
        (is= true (:read-only @(buffer-state todo-buffer)))
        (rebase/git-rebase-todo-abort)))
    (cleanup tmp-dir)))

(deftest regit-rebase-todo-mode-renders-action-face-and-bash-comments-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-todo-style")
        result (rebase/run-rebase-onto! tmp-dir (assoc base-rebase-args :interactive true) "origin/main")]
    (test/assert (not (string? result)) (str "interactive rebase failed: " result))
    (let [todo-buffer (focused-buffer)
          content (focused-display-content)]
      (binding [*buffer* todo-buffer
                *window* (focused-window)]
        (is= "bash" mode/*language*)
        (doseq [needle ["# p        pick = use commit"
                        "# r        reword = use commit, but edit the commit message"
                        "# e        edit = use commit, but stop for amending"
                        "# s        squash = use commit, but meld into previous commit"
                        "# f        fixup [-C | -c] <commit> = like \"squash\" but keep only the previous"
                        "# u        undo last change"
                        "# ZZ       tell Git to make it happen"
                        "# ZQ       tell Git that you changed your mind, i.e. abort"
                        "# k        move point to previous line"
                        "# j        move point to next line"
                        "# M-k      move the commit at point up"
                        "# M-j      move the commit at point down"
                        "# m, merge [-C <commit> | -c <commit>] <label> [# <oneline>]"]]
          (test/assert (str/includes? content needle)
            (str "todo help should mention " needle ". Got:\n" content)))
        (test/assert (str/includes? content "# s-k      move the commit at point up")
          (str "todo help should mention s-k. Got:\n" content))
        (test/assert (str/includes? content "# s-j      move the commit at point down")
          (str "todo help should mention s-j. Got:\n" content))
        (test/assert (str/includes? content "# <enter>  show the commit at point in another buffer")
          (str "todo help should mention <enter>. Got:\n" content))
        (doseq [needle ["# l, label"
                        "# t, reset"
                        "# u, update-ref"
                        "# z, noop"]]
          (test/assert (not (str/includes? content needle))
            (str "todo help should not include raw git command " needle ". Got:\n" content)))
        (let [enter-line (find-line content "# <enter>")
              merge-line (find-line content "# m, merge")]
          (test/assert (and enter-line merge-line (< enter-line merge-line))
            (str "extra todo help should be inserted above merge help. Got:\n" content)))
        (doseq [keys-str ["r" "w"]]
          (is= #'rebase/git-rebase-todo-reword
            (keys/lookup-keymap rebase/git-rebase-todo-keymap (keys/parse-key-sequence keys-str))))
        (test/assert (contains? (set *submodes*) :vim)
          (str "todo buffer should enable vim submode. Current submodes: " *submodes*))
        (doseq [keys-str ["r" "w"]]
          (is= #'rebase/git-rebase-todo-reword
            (keys/lookup-keys (keys/parse-key-sequence keys-str))))
        (doseq [keys-str ["Z Z" "Z Q" "r" "w" "u" "k" "j" "M-k" "M-j" "s-k" "s-j" "<enter>"]]
          (test/assert (ifn? (keys/lookup-keymap rebase/git-rebase-todo-keymap (keys/parse-key-sequence keys-str)))
            (str "todo key should be bound: " keys-str)))
        (doseq [keys-str ["c" "m" "l" "t" "M M" "M t" "<space>"]]
          (test/assert (nil? (keys/lookup-keymap rebase/git-rebase-todo-keymap (keys/parse-key-sequence keys-str)))
            (str "todo key should not be bound: " keys-str)))
        (let [action-span (first (filter #(and (= 0 (:start %)) (= 4 (:end %)))
                                   (buffer/property-spans todo-buffer)))
              actual-style (when action-span (style->map (:properties action-span)))
              expected-style (style->map (theme/style-for-face :git-rebase-todo-action))]
          (test/assert action-span (str "pick action should have a property span. Spans: " (buffer/property-spans todo-buffer)))
          (is= (:fg expected-style) (:fg actual-style)))
        (buffer/wait-for-syntax-highlighting todo-buffer)
        (let [comment-start (str/index-of content "# ")
              spans (tree-sitter-highlights-in-range comment-start (+ comment-start 8) todo-buffer)]
          (test/assert (some #(= "comment" (:type %)) spans)
            (str "todo text after # should receive bash comment highlighting. Spans: " spans)))
        (rebase/git-rebase-todo-abort)))
    (cleanup tmp-dir)))

(deftest regit-rebase-todo-key-events-update-commit-action-at-point-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-todo-key-events")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "- i")
    (assert-focused-command "Interactive" "interactive arg enabled before interactive action")
    (send-keys "i")
    (assert-focused-log-select
      "Type C-c C-c on a commit to rebase it and all commits above it"
      "interactive action with interactive arg")
    (pick-log-commit! 1)
    (assert-focused-todo "interactive arg plus interactive action picked commit")
    (let [line (move-focused-line-containing! "pick ")]
      (send-keys "r")
      (test/assert (str/starts-with? (focused-todo-line-at line) "reword ")
        (str "todo key r should change action to reword, got " (focused-todo-line-at line)))
      (is= (inc line) (focused-line))
      (send-keys "u")
      (move-focused-line! line)
      (test/assert (str/starts-with? (focused-todo-line-at line) "pick ")
        (str "todo key u should undo the action change, got " (focused-todo-line-at line)))
      (assert-focused-todo-action-face "pick" "todo key u"))
    (let [line (focused-line)]
      (binding [*buffer* (focused-buffer)]
        (is= #'rebase/git-rebase-todo-reword
          (keys/lookup-keys (keys/parse-key-sequence "w"))))
      (send-keys-queued "w")
      (test/assert (str/starts-with? (focused-todo-line-at line) "reword ")
        (str "todo key w should change action to reword, got " (focused-todo-line-at line)))
      (is= (inc line) (focused-line))
      (send-keys "u")
      (move-focused-line! line)
      (test/assert (str/starts-with? (focused-todo-line-at line) "pick ")
        (str "todo key u should undo the w action change, got " (focused-todo-line-at line)))
      (assert-focused-todo-action-face "pick" "todo key w then u"))
    (doseq [[key expected] [["e" "edit"]
                            ["s" "squash"]
                            ["f" "fixup"]
                            ["d" "drop"]
                            ["p" "pick"]]]
      (let [line (focused-line)]
        (send-keys key)
        (test/assert (str/starts-with? (focused-todo-line-at line) (str expected " "))
          (str "todo key " key " should change action to " expected ", got " (focused-todo-line-at line)))
        (is= (inc line) (focused-line))
        (move-focused-line! line))
      (test/assert (not (str/includes? (last-message) "No commit action at point"))
        (str "todo key " key " reported a missing commit action: " (last-message))))
    (move-focused-line! 1)
    (send-keys "k")
    (is= 0 (focused-line))
    (send-keys "j")
    (is= 1 (focused-line))
    (let [before-lines (focused-todo-lines)
          first-line (nth before-lines 0)
          second-line (nth before-lines 1)]
      (move-focused-line! 1)
      (send-keys "M-k")
      (is= second-line (first (focused-todo-lines)))
      (send-keys "M-j")
      (is= second-line (nth (focused-todo-lines) 1))
      (move-focused-line! 1)
      (send-keys "s-k")
      (is= second-line (first (focused-todo-lines)))
      (send-keys "s-j")
      (is= second-line (nth (focused-todo-lines) 1)))
    (move-focused-line! 0)
    (let [todo-window (focused-window)]
      (send-keys "<enter>")
      (test/assert (not= todo-window (focused-window)) "enter should open commit in another window")
      (test/assert (str/includes? (focused-buffer-name) "regit-commit")
        (str "enter should open regit-view-commit, got " (focused-buffer-name)))
      (test/assert (str/includes? (focused-content) "Commit:")
        (str "view commit buffer should contain commit details. Got:\n" (focused-content)))
      (send-keys "q")
      (test/assert (= todo-window (focused-window)) "closing commit view should return to todo window"))
    (send-keys "Z Q")
    (assert-focused-status tmp-dir "todo key event abort")
    (cleanup tmp-dir)))

(deftest regit-rebase-remove-commit-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-remove")
        two (subject-hash tmp-dir "two")
        err (rebase/run-rebase-remove-commit! tmp-dir base-rebase-args two)]
    (test/assert (not err) (str "remove rebase failed: " err))
    (test/assert (not (some #(= % "two") (log-subjects tmp-dir))) "removed commit should not remain in log")
    (test/assert (not (path-exists? (path-join tmp-dir "two.txt"))) "file introduced by removed commit should be gone")
    (cleanup tmp-dir)))

(deftest regit-rebase-edit-commit-status-and-in-progress-popup-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-edit")
        two (subject-hash tmp-dir "two")
        err (rebase/run-rebase-edit-commit! tmp-dir base-rebase-args two)]
    (test/assert (not err) (str "edit rebase failed: " err))
    (test/assert (rebase/rebase-in-progress? tmp-dir) "rebase should be in progress after edit action")
    (status/regit-status tmp-dir)
    (let [content (focused-content)]
      (test/assert (str/includes? content "Rebasing") "status should show rebase heading")
      (test/assert (str/includes? content "stop") "status should show stopped commit"))
    (rebase/regit-rebase tmp-dir)
    (let [ui-win (minibuffer-ui-window)
          ui-buf (window-buffer ui-win)]
      (binding [*buffer* ui-buf
                *window* ui-win
                *mode* :regit-command
                *submodes* #{}]
        (let [st @regit-command/*state*]
          (is= #{"r" "s" "e" "a"} (set (keys (:actions st)))))))
    (rebase/run-rebase-abort! tmp-dir)
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "rebase should be aborted")
    (cleanup tmp-dir)))

(deftest regit-rebase-interactive-onto-upstream-opens-todo-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-upstream-interactive")
        result (rebase/run-rebase-onto! tmp-dir (assoc base-rebase-args :interactive true) "origin/main")]
    (test/assert (not (string? result)) (str "interactive upstream rebase failed: " result))
    (let [todo-window (focused-window)
          todo-buffer (window-buffer todo-window)
          content (buffer-content todo-buffer)]
      (binding [*buffer* todo-buffer
                *window* todo-window
                *mode* :git-rebase-todo
                *submodes* #{}]
        (is= true (:read-only @(buffer-state todo-buffer)))
        (test/assert (str/includes? content "pick") "interactive upstream rebase should open todo buffer")
        (rebase/git-rebase-todo-abort)))
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-interactive-opens-and-edits-read-only-todo-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-interactive")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "i")
    (assert-focused-log-select
      "Type C-c C-c on a commit to rebase it and all commits above it"
      "interactive action")
    (pick-log-commit! 1)
    (assert-focused-todo "interactive action picked commit")
    (test/assert (str/includes? (focused-content) "pick") "todo should contain pick lines")
    (send-keys "e")
    (test/assert (str/includes? (focused-content) "edit ") "todo edit key should mutate read-only buffer")
    (test/assert (= true (:read-only @(buffer-state (focused-buffer)))) "todo buffer should remain read-only after edit")
    (send-keys "C-c C-k")
    (assert-focused-status tmp-dir "interactive action abort")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-subset-rebases-selected-range-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-subset")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "s")
    (choose-target! "newbase")
    (assert-focused-log-select
      "Type C-c C-c on a commit to rebase it and commits above it onto newbase"
      "subset action target selection")
    (pick-log-commit! 1)
    (assert-focused-status tmp-dir "subset action complete")
    (let [subjects (log-subjects tmp-dir)]
      (is= "three" (first subjects))
      (test/assert (some #(= % "newbase") subjects) "subset rebase should include new base")
      (test/assert (not (some #(= % "two") subjects)) "subset rebase should omit commits below selected range"))
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-modify-then-continue-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-modify-continue")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "m")
    (assert-focused-log-select "Type C-c C-c on a commit to edit it" "modify action")
    (pick-log-commit! 1)
    (assert-focused-status tmp-dir "modify action stopped")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "modify action should leave rebase in progress")
    (test/assert (str/includes? (focused-content) "Rebasing") "status should show rebase in progress")
    (test/assert (str/includes? (focused-content) "stop") "status should show stopped commit")
    (send-keys "r")
    (assert-focused-command "Continue" "in-progress rebase command")
    (test/assert (str/includes? (minibuffer-ui-content) "Abort") "in-progress command should show Abort")
    (send-keys "r")
    (assert-focused-status tmp-dir "continue rebase complete")
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "continue should finish rebase")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-continue-opens-regit-commit-editor-test
  (let [tmp-dir (init-conflicted-rebase-test-repo "regit-rebase-key-continue-editor")]
    (write-file (path-join tmp-dir "conflict.txt") "resolved\n")
    (git! tmp-dir "add" "conflict.txt")
    (status/regit-status tmp-dir)
    (assert-focused-status tmp-dir "resolved conflict before continue")
    (send-keys "r")
    (assert-focused-command "Continue" "in-progress rebase command before editor")
    (send-keys "r")
    (assert-focused-regit-commit "continue rebase editor")
    (test/assert (str/includes? (focused-buffer-name) "regit-commit-message HEAD")
      (str "continue rebase editor should use regular commit message buffer label, got " (focused-buffer-name)))
    (test/assert (str/includes? (focused-content) "feature conflict")
      (str "rebase editor should contain original commit message. Got:\n" (focused-content)))
    (assert-focused-commit-comments-dimmed "continue rebase editor")
    (set-string "resolved rebase message\n" (focused-buffer))
    (send-keys "C-c C-c")
    (test/wait-for [state {:rebasing? (rebase/rebase-in-progress? tmp-dir)
                           :subject (first (log-subjects tmp-dir))}]
      :until (and (not (:rebasing? state)) (= "resolved rebase message" (:subject state)))
      :timeout-message "submitted editor should finish rebase with the edited message")
    (wait-for-focused-status tmp-dir "continue rebase editor submitted")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-continue-editor-abort-test
  (let [tmp-dir (init-conflicted-rebase-test-repo "regit-rebase-key-continue-editor-abort")]
    (write-file (path-join tmp-dir "conflict.txt") "resolved\n")
    (git! tmp-dir "add" "conflict.txt")
    (status/regit-status tmp-dir)
    (assert-focused-status tmp-dir "resolved conflict before continue editor abort")
    (send-keys "r")
    (assert-focused-command "Continue" "in-progress rebase command before editor abort")
    (send-keys "r")
    (assert-focused-regit-commit "continue rebase editor before abort")
    (send-keys "C-c C-k")
    (wait-for-message "Aborted commit message edit" "continue rebase editor abort")
    (wait-for-focused-status tmp-dir "continue rebase editor aborted")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "aborted editor should leave rebase in progress")
    (rebase/run-rebase-abort! tmp-dir)
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-modify-then-skip-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-modify-skip")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "m")
    (assert-focused-log-select "Type C-c C-c on a commit to edit it" "modify action before skip")
    (pick-log-commit! 2)
    (assert-focused-status tmp-dir "modify action before skip stopped")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "modify action should leave rebase in progress")
    (send-keys "r")
    (assert-focused-command "Skip" "in-progress skip command")
    (send-keys "s")
    (assert-focused-status tmp-dir "skip rebase complete")
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "skip should finish rebase")
    (test/assert (str/includes? (messages-content) "Skipped rebase commit") "skip should report the skip command result")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-edit-in-progress-todo-and-abort-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-edit-todo")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "m")
    (assert-focused-log-select "Type C-c C-c on a commit to edit it" "modify action before edit todo")
    (pick-log-commit! 2)
    (assert-focused-status tmp-dir "modify action stopped before edit todo")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "modify action should leave rebase in progress")
    (send-keys "r")
    (assert-focused-command "Edit" "in-progress edit command")
    (send-keys "e")
    (assert-focused-todo "edit in-progress todo")
    (test/assert (str/includes? (focused-content) "pick") "editable todo should include remaining pick lines")
    (send-keys "C-c C-k")
    (assert-focused-status tmp-dir "abort from edit todo")
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "abort from todo should abort rebase")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-modify-then-abort-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-modify-abort")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "m")
    (assert-focused-log-select "Type C-c C-c on a commit to edit it" "modify action before abort")
    (pick-log-commit! 1)
    (assert-focused-status tmp-dir "modify action before abort stopped")
    (test/assert (rebase/rebase-in-progress? tmp-dir) "modify action should leave rebase in progress")
    (send-keys "r")
    (assert-focused-command "Abort" "in-progress abort command")
    (send-keys "a")
    (assert-focused-status tmp-dir "abort rebase complete")
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "abort action should stop rebase")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-reword-selected-commit-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-reword")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "w")
    (assert-focused-log-select "Type C-c C-c on a commit to reword its message" "reword action")
    (pick-log-commit! 1)
    (test/assert (= (focused-window) (minibuffer-window))
      (str "reword should focus simple-prompt, got " (focused-buffer-name)))
    (send-keys "<enter>")
    (assert-focused-status tmp-dir "reword action complete")
    (is= "three" (first (log-subjects tmp-dir)))
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-remove-selected-commit-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-remove")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "k")
    (assert-focused-log-select "Type C-c C-c on a commit to remove it" "remove action")
    (pick-log-commit! 1)
    (assert-focused-status tmp-dir "remove action complete")
    (test/assert (not (some #(= % "three") (log-subjects tmp-dir))) "remove should drop selected commit")
    (test/assert (not (path-exists? (path-join tmp-dir "three.txt"))) "remove should remove selected commit file")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-autosquash-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-autosquash")]
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "f")
    (assert-focused-status tmp-dir "autosquash action complete")
    (test/assert (not (rebase/rebase-in-progress? tmp-dir)) "autosquash should finish immediately with true editor")
    (test/assert (str/includes? (last-message) "Autosquash rebase finished") "autosquash should report success")
    (cleanup tmp-dir)))

(deftest regit-rebase-key-flow-onto-push-upstream-and-elsewhere-test
  (let [push-dir (init-rebase-test-repo "regit-rebase-key-push")]
    (open-rebase-command-from-status! push-dir)
    (send-keys "p")
    (assert-focused-status push-dir "push-remote rebase complete")
    (test/assert (str/includes? (last-message) "Rebased onto origin/main") "push target should be origin/main")
    (cleanup push-dir))
  (let [upstream-dir (init-rebase-test-repo "regit-rebase-key-upstream")]
    (open-rebase-command-from-status! upstream-dir)
    (send-keys "u")
    (assert-focused-status upstream-dir "upstream rebase complete")
    (test/assert (str/includes? (last-message) "Rebased onto origin/main") "upstream target should be origin/main")
    (cleanup upstream-dir))
  (let [elsewhere-dir (init-rebase-test-repo "regit-rebase-key-elsewhere")]
    (open-rebase-command-from-status! elsewhere-dir)
    (send-keys "e")
    (choose-target! "newbase")
    (assert-focused-status elsewhere-dir "elsewhere rebase complete")
    (test/assert (some #(= % "newbase") (log-subjects elsewhere-dir)) "elsewhere rebase should include selected target")
    (cleanup elsewhere-dir)))

(deftest regit-rebase-key-flow-interactive-onto-actions-open-todo-test
  (let [push-dir (init-rebase-test-repo "regit-rebase-key-push-interactive")]
    (open-rebase-command-from-status! push-dir)
    (send-keys "- i")
    (assert-focused-command "Interactive" "interactive arg enabled before push rebase")
    (send-keys "p")
    (assert-focused-todo "interactive push-remote rebase")
    (test/assert (str/includes? (focused-content) "pick") "interactive push rebase should open todo")
    (send-keys "C-c C-k")
    (assert-focused-status push-dir "interactive push abort")
    (cleanup push-dir))
  (let [upstream-dir (init-rebase-test-repo "regit-rebase-key-upstream-interactive-ui")]
    (open-rebase-command-from-status! upstream-dir)
    (send-keys "- i")
    (assert-focused-command "Interactive" "interactive arg enabled before upstream rebase")
    (send-keys "u")
    (assert-focused-todo "interactive upstream rebase")
    (test/assert (str/includes? (focused-content) "pick") "interactive upstream rebase should open todo")
    (send-keys "C-c C-k")
    (assert-focused-status upstream-dir "interactive upstream abort")
    (cleanup upstream-dir))
  (let [elsewhere-dir (init-rebase-test-repo "regit-rebase-key-elsewhere-interactive")]
    (open-rebase-command-from-status! elsewhere-dir)
    (send-keys "- i")
    (assert-focused-command "Interactive" "interactive arg enabled before elsewhere rebase")
    (send-keys "e")
    (choose-target! "newbase")
    (assert-focused-todo "interactive elsewhere rebase")
    (test/assert (str/includes? (focused-content) "pick") "interactive elsewhere rebase should open todo")
    (send-keys "C-c C-k")
    (assert-focused-status elsewhere-dir "interactive elsewhere abort")
    (cleanup elsewhere-dir)))

(deftest regit-rebase-key-flow-failed-command-messages-and-renders-status-test
  (let [tmp-dir (init-rebase-test-repo "regit-rebase-key-failure")]
    (write-file (path-join tmp-dir "one.txt") "dirty\n")
    (status/regit-status tmp-dir)
    (assert-focused-status tmp-dir "failure setup")
    (test/assert (str/includes? (focused-content) "Unstaged changes") "setup status should show unstaged changes")
    (open-rebase-command-from-status! tmp-dir)
    (send-keys "- A")
    (send-keys "e")
    (choose-target! "newbase")
    (test/assert (str/includes? (messages-content) "Rebase failed:")
      (str "failed rebase should call message, got " (messages-content)))
    (let [content (status-content tmp-dir)]
      (test/assert (str/includes? content "Unstaged changes") "status should still render unstaged changes after failure")
      (test/assert (str/includes? content "one.txt") "status should show the dirty file after failure")
      (test/assert (str/includes? content "Recent commits") "status should render recent commits after failure"))
    (assert-focused-status tmp-dir "after failed rebase")
    (cleanup tmp-dir)))
