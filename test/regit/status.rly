(ns regit.tests.status
  (:require [regit.status :as status]
            [regit.tests.util :refer [buffer-content-lines git! git-cmd sh!]]
            [relay.base.buffer :as buffer]
            [relay.base.frame :as frame]
            [relay.base.keys :as keys]
            [relay.base.mode :as mode]
            [relay.base.theme :as theme]
            [regit.command :as regit-command]
            [regit.diff :as regit-diff]
            [regit.preview :as regit-preview]
            [relay.string :as str]
            [relay.ui.outline :as outline]
            [relay.ui.iselect :as iselect]
            [relay.ui.simple-prompt :as simple-prompt]
            [relay.test :as test :refer [deftest is= is-error]]))

(defn- get-git-output [root & args]
  (let [result (apply git-cmd root args)]
    (when (zero? (:code result))
      (str/trim (:out result)))))

(defn- get-git-output-raw [root & args]
  (let [result (apply git-cmd root args)]
    (when (zero? (:code result))
      (:out result))))

(defn- init-conflicted-merge-repo-with-content [name base-content ours-content theirs-content]
  (let [tmp-dir (temp-file-path name)
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (git! tmp-dir "init")
        _ (git! tmp-dir "config" "user.name" "Relay Test")
        _ (git! tmp-dir "config" "user.email" "relay@example.com")
        conflict-path (path-join tmp-dir "conflict.txt")
        _ (write-file conflict-path base-content)
        _ (git! tmp-dir "add" "conflict.txt")
        _ (git! tmp-dir "commit" "-m" "initial")
        _ (git! tmp-dir "branch" "-M" "main")
        _ (git! tmp-dir "checkout" "-b" "feature")
        _ (write-file conflict-path theirs-content)
        _ (git! tmp-dir "commit" "-am" "feature conflict")
        _ (git! tmp-dir "checkout" "main")
        _ (write-file conflict-path ours-content)
        _ (git! tmp-dir "commit" "-am" "main conflict")
        merge-result (git-cmd tmp-dir "merge" "feature")]
    (test/assert (not (zero? (:code merge-result))) "merge should stop with a conflict")
    (test/assert (path-exists? (path-join tmp-dir ".git" "MERGE_HEAD")) "MERGE_HEAD should exist")
    tmp-dir))

(defn- init-conflicted-merge-repo [name]
  (init-conflicted-merge-repo-with-content name "base\n" "ours\n" "theirs\n"))

(defn- init-special-conflict-repo [name conflict-kind]
  (let [tmp-dir (temp-file-path name)
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (git! tmp-dir "init")
        _ (git! tmp-dir "config" "user.name" "Relay Test")
        _ (git! tmp-dir "config" "user.email" "relay@example.com")
        conflict-path (path-join tmp-dir "conflict.txt")]
    (if (= conflict-kind :both-added)
      (git! tmp-dir "commit" "--allow-empty" "-m" "initial")
      (do
        (write-file conflict-path "base\n")
        (git! tmp-dir "add" "conflict.txt")
        (git! tmp-dir "commit" "-m" "initial")))
    (git! tmp-dir "branch" "-M" "main")
    (git! tmp-dir "checkout" "-b" "feature")
    (case conflict-kind
      :deleted-by-them (sh! "rm" ["-f" (str conflict-path)])
      :deleted-by-us (write-file conflict-path "theirs\n")
      :both-added (write-file conflict-path "theirs\n")
      nil)
    (git! tmp-dir "add" "-A")
    (git! tmp-dir "commit" "-m" "feature conflict")
    (git! tmp-dir "checkout" "main")
    (case conflict-kind
      :deleted-by-them (write-file conflict-path "ours\n")
      :deleted-by-us (sh! "rm" ["-f" (str conflict-path)])
      :both-added (write-file conflict-path "ours\n")
      nil)
    (git! tmp-dir "add" "-A")
    (git! tmp-dir "commit" "-m" "main conflict")
    (let [merge-result (git-cmd tmp-dir "merge" "feature")]
      (test/assert (not (zero? (:code merge-result))) "merge should stop with a conflict")
      (test/assert (path-exists? (path-join tmp-dir ".git" "MERGE_HEAD")) "MERGE_HEAD should exist")
      tmp-dir)))

(defn- unmerged-index [root]
  (get-git-output root "ls-files" "-u" "--" "conflict.txt"))

(deftest commit-line-hash-face-test
  (let [line (status/commit-line {:id "abc1234" :refs [] :summary "summary"})]
    (test/assert (property-string? line) "commit-line should preserve styled commit hash")
    (test/assert (str/includes? line "abc1234 summary") "commit-line missing commit text")))

(deftest regit-status-linked-worktree-buffer-label-test
  (let [parent (temp-file-path "regit-status-worktree-label")
        root (path-join parent "relay")
        worktree (path-join parent "work1")
        label-buffer (create-buffer true)]
    (try
      (sh! "rm" ["-rf" parent])
      (sh! "mkdir" [parent])
      (sh! "mkdir" [(str root)])
      (git! root "init")
      (git! root "config" "user.name" "Relay Test")
      (git! root "config" "user.email" "relay@example.com")
      (git! root "commit" "--allow-empty" "-m" "initial")
      (git! root "branch" "-M" "main")
      (git! root "worktree" "add" "-b" "work1" (str worktree))
      (let [label (status/status-buffer-label worktree)
            prefix-length (count "regit-status: ")
            repo-end (+ prefix-length (count "relay"))
            slash-end (inc repo-end)
            worktree-end (+ slash-end (count "work1"))]
        (is= "regit-status: relay/work1" (str/strip-properties label))
        (binding [*buffer* label-buffer]
          (set-string label)
          (let [spans (buffer/property-spans label-buffer)
                span-at (fn [start end]
                          (first (filter #(and (= start (:start %))
                                            (= end (:end %)))
                                   spans)))
                repo-style (style->map (:properties (span-at prefix-length repo-end)))
                slash-style (style->map (:properties (span-at repo-end slash-end)))
                worktree-style (style->map (:properties (span-at slash-end worktree-end)))]
            (is= (:fg (style->map (theme/style-for-face :regit-repo)))
              (:fg repo-style))
            (is= (:fg (style->map (theme/style-for-face :default)))
              (:fg slash-style))
            (is= (theme/color-hex :maroon) (:fg worktree-style)))))
      (finally
        (kill-buffer label-buffer)
        (sh! "rm" ["-rf" parent])))))

(defn- find-cached-node [old-tree id]
  (get (status/index-tree-nodes old-tree) id))

(defn- find-line-index [lines pred]
  (some (fn [i] (when (pred (nth lines i)) i)) (range (count lines))))

(defn- find-line-index-after [lines start-idx pred]
  (when (and start-idx (< start-idx (count lines)))
    (some (fn [i] (when (pred (nth lines i)) i)) (range start-idx (count lines)))))

(defn- move-to-line-containing! [buffer window lines needle & [start]]
  (let [line (find-line-index-after lines (or start 0) #(str/includes? (str %) needle))]
    (test/assert line (str "Could not find line containing " needle " in " lines))
    (move-cursor (with-read-lock [lock (buffer-text buffer)] (buffer/line-to-char lock line)) false window)
    line))

(defn- wait-for-status-preview-buffer [status-buffer status-window target timeout-ms]
  (test/wait-for [preview (or (regit-preview/wait-for-preview-buffer status-buffer target 50)
                            (do
                              (binding [*buffer* status-buffer
                                        *window* status-window]
                                (status/update-status-preview!))
                              (regit-preview/wait-for-preview-buffer status-buffer target 50)))]
    :until preview
    :return preview
    :timeout-ms timeout-ms
    :interval-ms 50))

(defn- get-section-range [lines section-name]
  (let [start (find-line-index lines #(str/includes? % section-name))]
    (when start
      (let [end (or (find-line-index-after lines (inc start) #(or (str/includes? % "Unstaged changes")
                                                                (str/includes? % "Staged changes")
                                                                (str/includes? % "Recent commits")))
                  (count lines))]
        [start end]))))

(deftest regit-status-tree-walks-large-sections-iteratively-test
  (let [file-count 1000
        children (mapv (fn [i] {:id [:file :staged (str "file-" i)]}) (range file-count))
        cached-child {:id [:hunk :staged "cached" 1]}
        tree [{:id [:section :staged]
               :children children}
              {:id :cached-parent
               :children-cache (atom [cached-child])}]
        last-id [:file :staged (str "file-" (dec file-count))]
        ids (status/collect-node-ids tree)]
    (is= last-id (:id (find-cached-node tree last-id)))
    (test/assert (contains? ids last-id) "expected large section child id to be collected")
    (test/assert (contains? ids (:id cached-child)) "expected cached child id to be collected")))

(deftest regit-status-jump-to-file-test
  (let [tmp-dir (temp-file-path "regit-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "hello")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                test-line-idx (find-line-index lines #(str/includes? (str %) "test.txt"))]
            (test/assert test-line-idx "Could not find test.txt in status buffer")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock test-line-idx))
              false status-window)
            (status/regit-status-enter)
            (let [new-buffer (window-buffer status-window)]
              (is= (path-canonicalize file-path) (path-canonicalize (:file new-buffer))))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-jump-to-hunk-line-test
  (let [tmp-dir (temp-file-path "regit-hunk-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "line1\nline2\nline3\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file file-path "line1\nline2 modified\nline3\n")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                header-line-idx (find-line-index lines #(str/includes? (str %) "modified test.txt"))]
            (test/assert header-line-idx "Could not find file header in status buffer")
            (set-focused-window status-window)
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)] (buffer/line-to-char lock header-line-idx)) false status-window)
            (outline/toggle-fold)
            (let [lines (buffer-content-lines)
                  modified-line-idx (find-line-index lines #(str/includes? (str %) "+line2 modified"))]
              (test/assert modified-line-idx "Could not find modified line in status buffer")
              (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                             (buffer/line-to-char lock modified-line-idx))
                false status-window)
              (status/regit-status-enter)
              (let [new-buffer (window-buffer status-window)
                    new-cursor (current-line new-buffer)]
                (is= (path-canonicalize file-path) (path-canonicalize (:file new-buffer)))
                (is= 1 new-cursor)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-jump-to-file-from-staged-hunk-test
  (let [tmp-dir (temp-file-path "regit-hunk-test-repo-staged")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "line1\nline2\nline3\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file file-path "line1\nline2 modified\nline3\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                header-line-idx (find-line-index lines #(str/includes? (str %) "modified test.txt"))]
            (test/assert header-line-idx "Could not find file header in status buffer")
            (set-focused-window status-window)
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)] (buffer/line-to-char lock header-line-idx)) false status-window)
            (outline/toggle-fold)
            (let [lines (buffer-content-lines)
                  deleted-line-idx (find-line-index lines #(str/includes? (str %) "-line2"))]
              (test/assert deleted-line-idx "Could not find deleted line in staged section of status buffer")
              (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                             (buffer/line-to-char lock deleted-line-idx))
                false status-window)
              (status/regit-status-jump-to-file)
              (let [new-buffer (window-buffer status-window)
                    new-cursor (current-line new-buffer)]
                (is= (path-canonicalize file-path) (path-canonicalize (:file new-buffer)))
                (is= 1 new-cursor)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-enter-on-change-section-opens-view-diff-test
  (let [tmp-dir (temp-file-path "regit-status-enter-section-diff-test")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        index-path (path-join tmp-dir "index.txt")
        worktree-path (path-join tmp-dir "worktree.txt")
        _ (write-file index-path "keep\nremove\n")
        _ (write-file worktree-path "keep\nremove\n")
        _ (sh! "git" ["-C" tmp-dir "add" "index.txt" "worktree.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file index-path "keep\nstaged\n")
        _ (sh! "git" ["-C" tmp-dir "add" "index.txt"])
        _ (write-file worktree-path "keep\nunstaged\n")
        status-buffer (create-buffer)]
    (delete-other-windows)
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                unstaged-line (find-line-index lines #(str/includes? (str %) "Unstaged changes"))]
            (test/assert unstaged-line "Could not find Unstaged changes section")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock unstaged-line))
              false status-window)
            (status/regit-status-enter)
            (let [view-window (focused-window)
                  view-buffer (window-buffer view-window)]
              (test/assert (not= status-window view-window) "regit-view-diff did not open in another window")
              (binding [*window* view-window
                        *buffer* view-buffer]
                (is= :regit-view-diff *mode*)
                (let [text (with-read-lock [lock (buffer-text)]
                             (buffer/slice lock 0 (buffer/len-chars lock)))]
                  (test/assert (str/includes? text "Working tree diff")
                    (str "Unstaged section did not open working tree diff. Got: " text))
                  (test/assert (str/includes? text "worktree.txt | 2 +-")
                    (str "Unstaged diff missing summary for worktree.txt. Got: " text))
                  (test/assert (not (str/includes? text "index.txt | 2 +-"))
                    (str "Unstaged diff unexpectedly included staged summary. Got: " text)))))))
        (binding [*window* status-window
                  *buffer* status-buffer]
          (set-focused-window status-window)
          (let [lines (buffer-content-lines)
                staged-line (find-line-index lines #(str/includes? (str %) "Staged changes"))]
            (test/assert staged-line "Could not find Staged changes section")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock staged-line))
              false status-window)
            (status/regit-status-enter)
            (let [view-window (focused-window)
                  view-buffer (window-buffer view-window)]
              (test/assert (not= status-window view-window) "regit-view-diff did not open in another window")
              (binding [*window* view-window
                        *buffer* view-buffer]
                (is= :regit-view-diff *mode*)
                (let [text (with-read-lock [lock (buffer-text)]
                             (buffer/slice lock 0 (buffer/len-chars lock)))]
                  (test/assert (str/includes? text "Pending commit")
                    (str "Staged section did not open pending commit diff. Got: " text))
                  (test/assert (str/includes? text "index.txt | 2 +-")
                    (str "Staged diff missing summary for index.txt. Got: " text))
                  (test/assert (not (str/includes? text "worktree.txt | 2 +-"))
                    (str "Staged diff unexpectedly included unstaged summary. Got: " text)))))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-stash-test
  (let [tmp-dir (temp-file-path "regit-stash-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "hello\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file file-path "hello modified\n")
        _ (sh! "git" ["-C" tmp-dir "stash" "push" "-m" "test stash"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                stash-line-idx (find-line-index lines #(str/includes? (str %) "test stash"))]
            (test/assert stash-line-idx "Could not find test stash in status buffer")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock stash-line-idx))
              false status-window)
            (status/regit-status-enter)
            (let [new-buffer (window-buffer status-window)]
              (binding [*buffer* new-buffer]
                (is= :regit-view-stash *mode*)
                (let [text (with-read-lock [lock (buffer-text)]
                             (buffer/slice lock 0 (buffer/len-chars lock)))]
                  (test/assert (str/includes? text "Staged changes")
                    (str "regit-view-stash buffer missing Staged changes header. Got: " text))
                  (test/assert (str/includes? text "Unstaged changes")
                    (str "regit-view-stash buffer missing Unstaged changes header. Got: " text))
                  (let [view-lines (str/split-lines text)
                        file-idx (find-line-index view-lines #(str/includes? (str %) "test.txt"))]
                    (test/assert file-idx "Could not find test.txt in stash view")
                    (let [expanded-text (with-read-lock [lock (buffer-text)] (buffer/slice lock 0 (buffer/len-chars lock)))]
                      (test/assert (str/includes? expanded-text "+hello modified")
                        (str "regit-view-stash buffer missing expected diff content. Got: " expanded-text)))))))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-previews-commit-and-promotes-stash-test
  (let [tmp-dir (temp-file-path "regit-status-preview-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "one\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first preview commit"])
        _ (write-file file-path "two\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second preview commit"])
        _ (write-file file-path "stash change\n")
        _ (sh! "git" ["-C" tmp-dir "stash" "push" "-m" "preview stash"])
        status-buffer (create-buffer)]
    (delete-other-windows)
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                recent-header (find-line-index lines #(str/includes? (str %) "Recent commits"))
                recent-line (find-line-index-after lines (or recent-header 0) #(str/includes? (str %) "second preview commit"))
                stash-line (find-line-index lines #(str/includes? (str %) "preview stash"))]
            (test/assert recent-header "Could not find recent commits section")
            (test/assert recent-line "Could not find recent commit line")
            (test/assert stash-line "Could not find stash line")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock recent-line))
              false status-window)
            (let [commit-target (status/preview-target-at-line recent-line)
                  commit-preview (wait-for-status-preview-buffer status-buffer status-window commit-target 4000)]
              (test/assert commit-preview "Commit preview buffer was not displayed")
              (is= status-window (focused-window))
              (let [commit-preview-window (first (filter #(= (:id (window-buffer %)) (:id commit-preview))
                                                   (frame-normal-windows)))]
                (test/assert commit-preview-window "Commit preview window not found")
                (test/assert (not= status-window commit-preview-window) "Commit preview focused the status window")
                (binding [*window* commit-preview-window
                          *buffer* commit-preview]
                  (is= :regit-view-commit *mode*)
                  (let [text (with-read-lock [lock (buffer-text commit-preview)]
                               (buffer/slice lock 0 (buffer/len-chars lock)))]
                    (test/assert (str/includes? text "second preview commit")
                      (str "Commit preview missing commit summary. Got: " text))))
                (let [previous-hook regit-preview/*before-create-preview-buffer-hook*]
                  (set! regit-preview/*before-create-preview-buffer-hook*
                    (fn [] (sleep (ms->duration 150))))
                  (try
                    (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                                   (buffer/line-to-char lock stash-line))
                      false status-window)
                    (test/assert (some #(= (:id %) (:id commit-preview)) (list-buffers))
                      "Commit preview buffer was closed before the replacement preview was ready")
                    (is= commit-preview (window-buffer commit-preview-window))
                    (finally
                      (set! regit-preview/*before-create-preview-buffer-hook* previous-hook))))
                (let [stash-target (status/preview-target-at-line stash-line)
                      stash-preview (wait-for-status-preview-buffer status-buffer status-window stash-target 4000)]
                  (test/assert stash-preview "Stash preview buffer was not displayed")
                  (test/assert (regit-preview/wait-for-buffer-closed commit-preview 500)
                    "Commit preview buffer was not closed after the stash preview displayed")
                  (is= stash-preview (window-buffer commit-preview-window))
                  (move-cursor 0 false status-window)
                  (test/assert (regit-preview/wait-for-buffer-closed stash-preview 500)
                    "Stash preview buffer was not closed after cursor moved away")
                  (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                                 (buffer/line-to-char lock stash-line))
                    false status-window)
                  (let [preview-buffer (wait-for-status-preview-buffer status-buffer status-window stash-target 4000)]
                    (test/assert preview-buffer "Stash preview buffer was not displayed again")
                    (let [preview-window (first (filter #(= (:id (window-buffer %)) (:id preview-buffer))
                                                  (frame-normal-windows)))]
                      (test/assert preview-window "Stash preview window not found")
                      (status/regit-status-enter)
                      (is= preview-window (focused-window))
                      (is= preview-buffer (window-buffer preview-window))
                      (test/assert (not (regit-preview/active-preview status-buffer))
                        "Source status buffer still had active preview state after promotion")
                      (binding [*window* preview-window
                                *buffer* preview-buffer]
                        (is= :regit-view-stash *mode*)
                        (is= false outline/*show-arrows*)
                        (is= 0 outline/*indent-width*)
                        (test/assert (str/includes? (:name preview-buffer) "*regit-stash: stash@{0}*")
                          (str "Promoted stash preview kept preview name: " (:name preview-buffer))))
                      (set-focused-window status-window)
                      (move-cursor 0 false status-window)
                      (test/assert (some #(= (:id %) (:id preview-buffer)) (list-buffers))
                        "Promoted stash preview buffer was killed after moving the status cursor")))))))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-status-preview-disabled-test
  (let [tmp-dir (temp-file-path "regit-status-preview-disabled-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "preview disabled\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "disabled status preview commit"])
        status-buffer (create-buffer)
        previous-preview-on-focus regit-preview/regit-preview-on-focus]
    (delete-other-windows)
    (set! regit-preview/regit-preview-on-focus false)
    (try
      (binding [*buffer* status-buffer]
        (status/regit-status tmp-dir)
        (let [status-window (focused-window)
              status-buffer (window-buffer status-window)]
          (binding [*window* status-window
                    *buffer* status-buffer]
            (let [lines (buffer-content-lines)
                  recent-header (find-line-index lines #(str/includes? (str %) "Recent commits"))
                  recent-line (find-line-index-after lines (or recent-header 0) #(str/includes? (str %) "disabled status preview commit"))]
              (test/assert recent-header "Could not find recent commits section")
              (test/assert recent-line "Could not find disabled status preview commit line")
              (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                             (buffer/line-to-char lock recent-line))
                false status-window)
              (sleep (ms->duration 100))
              (test/assert (not (regit-preview/active-preview status-buffer))
                "Status preview state was created while regit-preview-on-focus was false")
              (test/assert (not (some #(:regit-preview? @(buffer-state %)) (list-buffers)))
                "Status preview buffer was created while regit-preview-on-focus was false")))))
      (finally
        (set! regit-preview/regit-preview-on-focus previous-preview-on-focus)
        (sh! "rm" ["-rf" tmp-dir])))))

(deftest regit-status-apply-stash-test
  (let [tmp-dir (temp-file-path "regit-status-apply-stash-test")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "hello\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file file-path "hello modified\n")
        _ (sh! "git" ["-C" tmp-dir "stash" "push" "-m" "test stash"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                stash-line-idx (find-line-index lines #(str/includes? (str %) "test stash"))]
            (test/assert stash-line-idx "Could not find test stash in status buffer")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock stash-line-idx))
              false status-window)
            (status/regit-status-apply)
            (let [text (with-read-lock [lock (buffer-text status-buffer)]
                         (buffer/slice lock 0 (buffer/len-chars lock)))]
              (test/assert (str/includes? text "test.txt")
                (str "Status buffer missing test.txt after stash apply. Got: " text))
              (test/assert (str/includes? text "Unstaged changes")
                (str "Status buffer missing Unstaged changes header after stash apply. Got: " text)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-apply-stash-refreshes-after-failure-test
  (let [tmp-dir (temp-file-path "regit-status-apply-stash-refreshes-after-failure-test")
