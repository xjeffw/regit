(deftest regit-status-discard-stash-requires-confirmation-test
  (let [tmp-dir (temp-file-path "regit-status-discard-stash-test")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "hello\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial"])
        _ (write-file file-path "hello modified\n")
        _ (sh! "git" ["-C" tmp-dir "stash" "push" "-m" "drop me"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                stash-line-idx (find-line-index lines #(str/includes? (str %) "drop me"))]
            (test/assert stash-line-idx "Could not find stash in status buffer")
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock stash-line-idx))
              false status-window)
            (status/regit-discard)
            (let [mb-win (minibuffer-window)]
              (test/assert mb-win "minibuffer-window not opened for stash discard confirmation")
              (let [mb-buf (window-buffer mb-win)]
                (binding [*buffer* mb-buf
                          *window* mb-win]
                  (let [prompt (:prompt @simple-prompt/*state*)]
                    (test/assert (str/includes? (str prompt) "drop me")
                      (str "stash discard prompt did not include stash name. Got: " prompt))
                    (test/assert (str/includes? (str prompt) "Type [y] to confirm")
                      (str "stash discard prompt did not include single-key confirmation. Got: " prompt)))
                  (simple-prompt/simple-prompt-append-char "n"))))
            (is= 1 (count (git-stashes tmp-dir)))
            (status/regit-discard)
            (let [mb-win (minibuffer-window)]
              (test/assert mb-win "minibuffer-window not opened for stash discard confirmation")
              (let [mb-buf (window-buffer mb-win)]
                (binding [*buffer* mb-buf
                          *window* mb-win]
                  (simple-prompt/simple-prompt-append-char "y"))))
            (is= 0 (count (git-stashes tmp-dir)))
            (let [text (with-read-lock [lock (buffer-text status-buffer)]
                         (buffer/slice lock 0 (buffer/len-chars lock)))]
              (test/assert (not (str/includes? text "drop me"))
                (str "Status buffer still included dropped stash. Got: " text)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-draw-all-for-library-buffer-test
  (let [tmp-dir (temp-file-path "regit-test-repo-draw")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "hello")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)
            initial-buffer-count (count (list-buffers))]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (is= true (:read-only @(buffer-state status-buffer)))
          (is= :regit-status *mode*)
          (status/regit-status tmp-dir)
          (let [second-status-buffer (window-buffer (focused-window))]
            (is= (:id status-buffer) (:id second-status-buffer))
            (is= initial-buffer-count (count (list-buffers)))
            (let [content (with-read-lock [lock (buffer-text status-buffer)] (buffer/slice lock 0 (buffer/len-chars lock)))]
              (test/assert (str/includes? content "Repository:") "expected regit repository heading")
              (test/assert (not (str/includes? content "Branch:")) "did not expect old branch heading")
              (test/assert (str/includes? content "Head:") "expected regit head summary")
              (test/assert (str/includes? content tmp-dir) "expected regit repository root"))
            (let [label (:label @(buffer-state status-buffer))]
              (test/assert (property-string? label) "regit-status label should preserve styled spans")
              (test/assert (str/includes? label "regit-status: ") "regit-status label missing prefix")
              (test/assert (str/includes? label (path-filename tmp-dir)) "regit-status label missing repo name"))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-show-commands-layout-test
  (let [tmp-dir (temp-file-path "regit-status-show-commands")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (status/regit-status-show-commands)
      (let [ui-win (minibuffer-ui-window)]
        (test/assert ui-win "minibuffer-ui-window not opened")
        (let [ui-buf (window-buffer ui-win)
              text (with-read-lock [lock (buffer-text ui-buf)]
                     (buffer/slice lock 0 (buffer/len-chars lock)))]
          (doseq [expected ["Transient and dwim commands"
                            "Applying changes"
                            "Essential commands"
                            "Branch"
                            "Commit"
                            "Fetch"
                            "Pull"
                            "Log"
                            "Push"
                            "Stash"
                            "Worktree"
                            "Help"
                            "Apply"
                            "Stage"
                            "Unstage"
                            "Discard"
                            "Close buffer"
                            "Toggle section at point"
                            "Visit thing at point"
                            "Visit file at point"]]
            (test/assert (str/includes? text expected)
              (str "regit status help missing " expected ": " text)))
          (let [lines (vec (str/split text #"\n"))
                essential-idx (find-line-index lines #(str/includes? % "Essential commands"))]
            (test/assert essential-idx "missing Essential commands heading")
            (let [first-row (get lines (inc essential-idx))
                  second-row (get lines (+ essential-idx 2))]
              (test/assert (and (str/includes? first-row "Close buffer")
                             (str/includes? first-row "Toggle section at point")
                             (not (str/includes? first-row "Visit thing at point")))
                (str "expected Essential commands first row to use two columns: " first-row))
              (test/assert (and (str/includes? second-row "Visit thing at point")
                             (str/includes? second-row "Visit file at point"))
                (str "expected Essential commands second row to use two columns: " second-row))
              (is= (str/index-of first-row "<tab>") (str/index-of second-row "C-<enter>"))))
          (binding [*buffer* ui-buf
                    *window* ui-win
                    *mode* :regit-command
                    *submodes* #{}]
            (doseq [key ["b" "c" "f" "F" "l" "P" "z" "Z" "?" "a" "s" "u" "x" "q" "<enter>" "C-<enter>"]]
              (test/assert (ifn? (regit-command/regit-command-keymap (keys/parse-key-sequence key)))
                (str "missing regit status help command key: " key)))
            (let [close-cmd (regit-command/regit-command-keymap (keys/parse-key-sequence "q"))]
              (when (ifn? close-cmd)
                (close-cmd)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-branch-summary-test
  (let [tmp-dir (temp-file-path "regit-branch-summary-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        _ (sh! "git" ["-C" tmp-dir "remote" "add" "origin" "https://example.invalid/relay.git"])
        tracked (path-join tmp-dir "tracked.txt")
        subject "test runner output formatting and colors"
        _ (write-file tracked "hello\n")
        _ (sh! "git" ["-C" tmp-dir "add" "tracked.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" subject])
        _ (sh! "git" ["-C" tmp-dir "branch" "-M" "main"])
        _ (sh! "git" ["-C" tmp-dir "update-ref" "refs/remotes/origin/main" "HEAD"])
        _ (sh! "git" ["-C" tmp-dir "branch" "--set-upstream-to" "origin/main" "main"])
        _ (sh! "git" ["-C" tmp-dir "config" "pull.rebase" "true"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [content (with-read-lock [lock (buffer-text status-buffer)] (buffer/slice lock 0 (buffer/len-chars lock)))
                repository-idx (str/index-of content "Repository:")
                head-idx (str/index-of content (str "Head:        main " subject))]
            (test/assert head-idx "expected regit head summary")
            (test/assert (str/includes? content (str "Rebase:      origin/main " subject)) "expected regit rebase summary")
            (test/assert (str/includes? content (str "Push:        origin/main " subject)) "expected regit push summary")
            (test/assert (not (str/includes? content "Branch:")) "did not expect old branch heading")
            (test/assert (and repository-idx head-idx (< repository-idx head-idx))
              "expected branch summary inside repository heading")))))
    (sh! "rm" ["-rf" tmp-dir])))

