(deftest regit-status-enter-on-branch-summary-opens-log-target-test
  (let [tmp-dir (temp-file-path "regit-branch-summary-enter-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        _ (sh! "git" ["-C" tmp-dir "remote" "add" "origin" "https://example.invalid/relay.git"])
        tracked (path-join tmp-dir "tracked.txt")
        _ (write-file tracked "main\n")
        _ (sh! "git" ["-C" tmp-dir "add" "tracked.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "main commit"])
        _ (sh! "git" ["-C" tmp-dir "branch" "-M" "main"])
        _ (sh! "git" ["-C" tmp-dir "checkout" "-b" "remote-seed"])
        _ (write-file tracked "remote\n")
        _ (sh! "git" ["-C" tmp-dir "add" "tracked.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "remote commit"])
        _ (sh! "git" ["-C" tmp-dir "update-ref" "refs/remotes/origin/main" "HEAD"])
        _ (sh! "git" ["-C" tmp-dir "checkout" "main"])
        _ (sh! "git" ["-C" tmp-dir "branch" "--set-upstream-to" "origin/main" "main"])
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                push-line-idx (find-line-index lines #(str/includes? (str %) "Push:"))
                item (get (:line-to-item @(buffer-state status-buffer)) push-line-idx)]
            (test/assert push-line-idx "Could not find Push line in status buffer")
            (is= "origin/main" (:log-ref item))
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                           (buffer/line-to-char lock push-line-idx))
              false status-window)
            (status/regit-status-enter)
            (let [log-buffer (window-buffer status-window)]
              (binding [*window* status-window
                        *buffer* log-buffer]
                (is= :regit-log *mode*)
                (let [text (with-read-lock [lock (buffer-text log-buffer)]
                             (buffer/slice lock 0 (buffer/len-chars lock)))]
                  (test/assert (str/includes? text "Commits in origin/main") "regit-log missing target header")
                  (test/assert (str/includes? text "remote commit") "regit-log missing target commit"))))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-initially-hides-file-diffs-test
  (let [tmp-dir (temp-file-path "regit-hides-diffs-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        tracked (path-join tmp-dir "tracked.txt")
        binary (path-join tmp-dir "image.png")
        _ (write-file tracked "before\n")
        _ (sh! "git" ["-C" tmp-dir "add" "tracked.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial commit"])
        _ (write-file tracked "after\n")
        _ (write-file binary "fake png data")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [content (with-read-lock [lock (buffer-text status-buffer)] (buffer/slice lock 0 (buffer/len-chars lock)))]
            (test/assert (str/includes? content "Untracked files (1)") "expected untracked section")
            (test/assert (str/includes? content "Unstaged changes (1)") "expected unstaged section")
            (test/assert (str/includes? content "modified tracked.txt") "expected tracked file header")
            (test/assert (str/includes? content "image.png") "expected untracked file path")
            (test/assert (not (str/includes? content "untracked image.png")) "expected untracked files to render without a status prefix")
            (test/assert (not (str/includes? content "+after")) "diff content should not be rendered initially")))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-stage-and-unstage-file-entry-test
  (let [tmp-dir (temp-file-path "regit-stage-unstage-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Relay Test"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "relay@example.com"])
        tracked (path-join tmp-dir "tracked.txt")
        _ (write-file tracked "before\n")
        _ (sh! "git" ["-C" tmp-dir "add" "tracked.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "initial commit"])
        _ (write-file tracked "after\n")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                file-line (find-line-index lines (fn [l] (str/includes? (str l) "modified tracked.txt")))]
            (move-cursor (with-read-lock [lock (buffer-text status-buffer)] (buffer/line-to-char lock file-line)) false status-window)
            (status/regit-stage)
            (let [staged-diff (get-git-output tmp-dir "diff" "--cached" "--" "tracked.txt")
                  unstaged-diff (get-git-output tmp-dir "diff" "--" "tracked.txt")]
              (test/assert (str/includes? (str staged-diff) "+after") "expected staged diff to contain +after")
              (test/assert (str/blank? unstaged-diff) "expected unstaged diff to be empty"))
            (let [lines (buffer-content-lines)
                  staged-section (find-line-index lines (fn [l] (str/includes? (str l) "Staged changes (1)")))
                  staged-file-line (find-line-index-after lines (if staged-section (inc staged-section) 0) (fn [l] (str/includes? (str l) "modified tracked.txt")))]
              (move-cursor (with-read-lock [lock (buffer-text status-buffer)] (buffer/line-to-char lock staged-file-line)) false status-window)
              (status/regit-unstage)
              (let [staged-diff (get-git-output tmp-dir "diff" "--cached" "--" "tracked.txt")
                    unstaged-diff (get-git-output tmp-dir "diff" "--" "tracked.txt")]
                (test/assert (str/blank? staged-diff) "expected staged diff to be empty")
                (test/assert (str/includes? (str unstaged-diff) "+after") "expected unstaged diff to contain +after")))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-unstage-unresolved-conflict-from-staged-section-test
  (let [tmp-dir (init-conflicted-merge-repo "regit-status-conflict-unstage")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
                staged-section (find-line-index lines #(str/includes? (str %) "Staged changes"))]
            (test/assert staged-section (str "Missing staged section in " lines))
            (move-to-line-containing! status-buffer status-window lines "both modified conflict.txt" staged-section)
            (status/regit-unstage)
            (test/assert (str/blank? (unmerged-index tmp-dir)) "unstage should clear unmerged index entries")
            (let [porcelain (get-git-output-raw tmp-dir "status" "--porcelain")]
              (test/assert (str/includes? porcelain " M conflict.txt")
                (str "unstage should leave conflict markers as an unstaged worktree change. Got: " porcelain)))
            (let [content (with-read-lock [lock (buffer-text status-buffer)]
                            (buffer/slice lock 0 (buffer/len-chars lock)))]
              (test/assert (str/includes? content "Merging feature:") "status should still show merge in progress")
              (test/assert (str/includes? content "modified conflict.txt")
                (str "status should rerender conflict as unstaged modified file. Got: " content)))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-shows-special-merge-state-labels-test
  (doseq [case-data [[:deleted-by-them "UD conflict.txt" "deleted by them conflict.txt"]
                     [:deleted-by-us "DU conflict.txt" "deleted by us conflict.txt"]
                     [:both-added "AA conflict.txt" "both added conflict.txt"]]]
    (let [conflict-kind (nth case-data 0)
          porcelain-fragment (nth case-data 1)
          label (nth case-data 2)
          tmp-dir (init-special-conflict-repo (str "regit-status-" (name conflict-kind)) conflict-kind)
          status-buffer (create-buffer)]
      (binding [*buffer* status-buffer]
        (status/regit-status tmp-dir)
        (let [status-window (focused-window)
              status-buffer (window-buffer status-window)]
          (binding [*window* status-window
                    *buffer* status-buffer]
            (let [porcelain (get-git-output-raw tmp-dir "status" "--porcelain")
                  content (with-read-lock [lock (buffer-text status-buffer)]
                            (buffer/slice lock 0 (buffer/len-chars lock)))]
              (test/assert (str/includes? porcelain porcelain-fragment)
                (str "expected raw porcelain state " porcelain-fragment ". Got: " porcelain))
              (test/assert (str/includes? content label)
                (str "expected status label " label ". Got: " content))))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-status-stage-and-unstage-resolved-conflict-file-test
  (let [tmp-dir (init-conflicted-merge-repo "regit-status-conflict-stage")
        conflict-path (path-join tmp-dir "conflict.txt")
        status-buffer (create-buffer)]
    (write-file conflict-path "resolved\n")
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)]
            (move-to-line-containing! status-buffer status-window lines "both modified conflict.txt")
            (status/regit-stage)
            (test/assert (str/blank? (unmerged-index tmp-dir)) "stage should clear unmerged index entries")
            (let [staged-diff (get-git-output tmp-dir "diff" "--cached" "--" "conflict.txt")]
              (test/assert (str/includes? (str staged-diff) "+resolved")
                (str "staged resolution should contain +resolved. Got: " staged-diff)))
            (let [lines (buffer-content-lines)
                  staged-section (find-line-index lines #(str/includes? (str %) "Staged changes"))]
              (test/assert staged-section (str "Missing staged section after stage in " lines))
              (move-to-line-containing! status-buffer status-window lines "modified conflict.txt" staged-section)
              (status/regit-unstage)
              (let [staged-diff (get-git-output tmp-dir "diff" "--cached" "--" "conflict.txt")
                    unstaged-diff (get-git-output tmp-dir "diff" "--" "conflict.txt")]
                (test/assert (str/blank? staged-diff) "unstage should clear staged resolution")
                (test/assert (str/includes? (str unstaged-diff) "+resolved")
                  "unstage should leave resolved content in worktree")))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-conflict-hunk-stage-shows-magit-error-test
  (let [tmp-dir (init-conflicted-merge-repo "regit-status-conflict-hunk-error")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [raw-diff (get-git-output tmp-dir "diff" "--cc" "--no-ext-diff" "--" "conflict.txt")]
            (test/assert (str/includes? (str raw-diff) "@@@")
              (str "raw conflict diff should include combined hunk. Got: " raw-diff)))
          (let [lines (buffer-content-lines)
                file-line (move-to-line-containing! status-buffer status-window lines "both modified conflict.txt")]
            (let [item (get (:line-to-item @(buffer-state status-buffer)) file-line)
                  children (:children item)
                  deferred (:deferred-children item)
                  entry (:entry item)]
              (test/assert (or (seq children) deferred)
                "conflict file item should have deferred diff children")
              (test/assert (str/includes? (str (:diff entry)) "@@@")
                (str "conflict file entry should carry combined diff. Got: " (:diff entry)))
              (let [generated (regit-diff/make-file-entry-items entry {:path-section :unstaged
                                                                       :hunk-id-section :unstaged
                                                                       :include-patch? true
                                                                       :include-entry? true})]
                (test/assert (seq generated)
                  (str "combined conflict diff should generate hunk items. Diff: " (:diff entry)))))
            (outline/toggle-fold)
            (let [expanded-lines (buffer-content-lines)
                  hunk-line (find-line-index-after expanded-lines (inc file-line) #(str/includes? (str %) "@@@"))]
              (test/assert hunk-line (str "Could not find combined conflict hunk in " expanded-lines))
              (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
                             (buffer/line-to-char lock hunk-line))
                false status-window)
              (status/regit-stage)
              (let [messages (with-read-lock [lock (buffer-text (buffer/get-buffer "*Messages*"))]
                               (buffer/slice lock 0 (buffer/len-chars lock)))]
                (test/assert (str/includes? messages "Cannot un-/stage resolution hunks. Stage the whole file")
                  (str "expected Magit conflict hunk error. Messages: " messages)))
              (let [content (with-read-lock [lock (buffer-text status-buffer)]
                              (buffer/slice lock 0 (buffer/len-chars lock)))]
                (test/assert (str/includes? content "Merging feature:")
                  "status should rerender after failed conflict hunk operation")))))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-status-conflict-hunk-unstage-shows-magit-error-test
  (let [tmp-dir (init-conflicted-merge-repo "regit-status-conflict-hunk-unstage-error")
        status-buffer (create-buffer)]
    (binding [*buffer* status-buffer]
      (status/regit-status tmp-dir)
      (let [status-window (focused-window)
            status-buffer (window-buffer status-window)]
        (binding [*window* status-window
                  *buffer* status-buffer]
          (let [lines (buffer-content-lines)
