            (test/assert staged-section (str "Missing staged section in " lines))
            (let [file-line (move-to-line-containing! status-buffer status-window lines "both modified conflict.txt" staged-section)]
              (outline/toggle-fold)
              (let [expanded-lines (buffer-content-lines)
                    hunk-line (find-line-index-after expanded-lines (inc file-line) #(str/includes? (str %) "@@@"))]
                (test/assert hunk-line (str "Could not find staged combined conflict hunk in " expanded-lines))
                (move-cursor (with-read-lock [lock (buffer-text status-buffer)]
