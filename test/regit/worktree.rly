(ns regit.tests.worktree
  (:require [regit.worktree :as worktree]
            [regit.status :as status]
            [regit.tests.util :refer [assert-command-contains
                                      branch-present?
                                      cleanup
                                      command-state
                                      git!
                                      init-test-repo
                                      invoke-command-key!
                                      invoke-status-key!
                                      iselect-state
                                      select-current-iselect-entry!
                                      set-iselect-input!
                                      submit-simple-prompt!
                                      wait-for-focused-status]]
            [relay.base.buffer :as buffer]
            [relay.base.keys :as keys]
            [relay.string :as str]
            [relay.test :as test :refer [deftest is=]]
            [relay.ui.simple-prompt :as simple-prompt]))

(defn- linked-worktree [root name branch]
  (let [path (temp-file-path name)]
    (cleanup path)
    (git! root "worktree" "add" "-b" branch path "HEAD")
    path))

(defn- prompt-state []
  (let [win (minibuffer-window)
        buf (when win (window-buffer win))]
    (test/assert buf "simple prompt not open")
    (binding [*window* win
              *buffer* buf]
      @simple-prompt/*state*)))

(deftest regit-worktree-layout-and-status-binding-test
  (let [root (init-test-repo "regit-worktree-layout")]
    (status/regit-status root)
    (let [binding (keys/lookup-keymap status/regit-status-keymap
                    (keys/parse-key-sequence "Z"))]
      (test/assert (ifn? binding) "regit-status did not bind Z to regit-worktree"))
    (invoke-status-key! "Z")
    (let [state (command-state)]
      (doseq [key ["b" "c" "m" "k" "g"]]
        (test/assert (contains? (:actions state) key)
          (str "missing worktree action " key))))
    (doseq [needle ["Create new"
                    "Commands"
                    "worktree"
                    "branch and worktree"
                    "Move worktree"
                    "Delete worktree"
                    "Visit worktree"]]
      (assert-command-contains needle))
    (let [text (str/strip-properties
                 (with-read-lock [lock (buffer-text (window-buffer (minibuffer-ui-window)))]
                   (buffer/slice lock 0 (buffer/len-chars lock))))
          lines (str/split-lines text)]
      (test/assert (str/includes? (first lines) "Create new")
        (str "expected side-by-side Create new section, got: " text))
      (test/assert (str/includes? (first lines) "Commands")
        (str "expected side-by-side Commands section, got: " text)))
    (cleanup root)))

(deftest regit-worktree-list-and-checkout-targets-test
  (let [root (init-test-repo "regit-worktree-list")
        linked (linked-worktree root "regit-worktree-list-linked" "topic")
        result (worktree/list-worktrees root)
        entries (:worktrees result)]
    (is= nil (:error result))
    (is= 2 (count entries))
    (is= (str (path-canonicalize root))
      (str (path-canonicalize (:path (first entries)))))
    (is= "main" (:branch (first entries)))
    (is= "topic" (:branch (second entries)))
    (test/assert (seq (:head (second entries))) "linked worktree should include HEAD")
    (let [targets (set (worktree/checkout-targets root))]
      (test/assert (not (contains? targets "main"))
        "already checked-out main branch should not be offered")
      (test/assert (not (contains? targets "topic"))
        "already checked-out topic branch should not be offered")
      (test/assert (contains? targets "HEAD") "HEAD should be offered as a revision"))
    (cleanup linked root)))

(deftest regit-worktree-directory-default-matches-magit-sibling-style-test
  (let [parent (temp-file-path "regit-worktree-default-parent")
        root (path-join parent "relay_work1")]
    (is= (str (path-join parent "relay_feature-keyword"))
      (str (worktree/worktree-directory-default root "feature/keyword")))
    (is= (str (path-join parent "relay_"))
      (str (worktree/worktree-directory-default root nil)))))

(deftest regit-worktree-create-existing-branch-interface-test
  (let [root (init-test-repo "regit-worktree-create-existing")
        directory (temp-file-path "regit-worktree-create-existing-out")]
    (cleanup directory)
    (git! root "branch" "topic")
    (status/regit-status root)
    (invoke-status-key! "Z")
    (invoke-command-key! "b")
    (let [entries (:entries (iselect-state))]
      (test/assert (some #(= % "topic") entries) "topic branch missing from checkout choices")
      (test/assert (not (some #(= % "main") entries))
        "checked-out main branch should be omitted"))
    (set-iselect-input! "topic")
    (select-current-iselect-entry!)
    (is= (str (worktree/worktree-directory-default root "topic"))
      (simple-prompt/current-input))
    (submit-simple-prompt! directory)
    (test/assert (path-exists? (path-join directory "test.txt"))
      "new worktree should contain the checked-out files")
    (is= "topic" (git-current-branch directory))
    (wait-for-focused-status directory "create existing worktree")
    (cleanup directory root)))

(deftest regit-worktree-create-branch-interface-test
  (let [root (init-test-repo "regit-worktree-create-branch")
        directory (temp-file-path "regit-worktree-create-branch-out")]
    (cleanup directory)
    (status/regit-status root)
    (invoke-status-key! "Z")
    (invoke-command-key! "c")
    (is= "In new worktree; checkout new branch named:" (:prompt (prompt-state)))
    (submit-simple-prompt! "feature/new-ui")
    (set-iselect-input! "main")
    (select-current-iselect-entry!)
    (is= (str (worktree/worktree-directory-default root "feature/new-ui"))
      (simple-prompt/current-input))
    (submit-simple-prompt! directory)
    (test/assert (branch-present? root "feature/new-ui"))
    (is= "feature/new-ui" (git-current-branch directory))
    (wait-for-focused-status directory "create branch and worktree")
    (cleanup directory root)))

(deftest regit-worktree-move-interface-and-main-protection-test
  (let [root (init-test-repo "regit-worktree-move")
        linked (linked-worktree root "regit-worktree-move-linked" "topic")
        destination (temp-file-path "regit-worktree-move-destination")]
    (cleanup destination)
    (test/assert (str/includes? (worktree/move-worktree! root root destination)
                   "main working tree")
      "moving the main worktree should be rejected")
    (status/regit-status root)
    (invoke-status-key! "Z")
    (invoke-command-key! "m")
    (is= [linked] (:entries (iselect-state)))
    (select-current-iselect-entry!)
    (is= "Move worktree to:" (:prompt (prompt-state)))
    (submit-simple-prompt! destination)
    (test/assert (not (path-exists? linked)) "old worktree path should be gone")
    (test/assert (path-exists? (path-join destination "test.txt"))
      "moved worktree should exist at its destination")
    (is= "topic" (git-current-branch destination))
    (cleanup destination root)))

(deftest regit-worktree-delete-confirms-dirty-worktree-test
  (let [root (init-test-repo "regit-worktree-delete-dirty")
        linked (linked-worktree root "regit-worktree-delete-dirty-linked" "topic")]
    (write-file (path-join linked "dirty.txt") "dirty\n")
    (status/regit-status root)
    (invoke-status-key! "Z")
    (invoke-command-key! "k")
    (select-current-iselect-entry!)
    (test/assert (str/includes? (:prompt (prompt-state)) "despite uncommitted changes")
      "dirty worktree deletion should use the danger confirmation")
    (submit-simple-prompt! "n")
    (test/assert (path-exists? linked) "declining confirmation should keep the worktree")
    (invoke-status-key! "Z")
    (invoke-command-key! "k")
    (select-current-iselect-entry!)
    (submit-simple-prompt! "y")
    (test/assert (not (path-exists? linked)) "confirmed deletion should remove the worktree")
    (is= 1 (count (:worktrees (worktree/list-worktrees root))))
    (cleanup root)))

(deftest regit-worktree-delete-protects-main-and-prunes-missing-entry-test
  (let [root (init-test-repo "regit-worktree-delete-prune")
        linked (linked-worktree root "regit-worktree-delete-prune-linked" "topic")]
    (test/assert (str/includes? (worktree/delete-worktree! root root) "shared .git")
      "deleting the main worktree should be rejected")
    (cleanup linked)
    (is= nil (worktree/delete-worktree! root linked))
    (is= 1 (count (:worktrees (worktree/list-worktrees root))))
    (cleanup root)))

(deftest regit-worktree-visit-opens-selected-status-test
  (let [root (init-test-repo "regit-worktree-visit")
        linked (linked-worktree root "regit-worktree-visit-linked" "topic")]
    (status/regit-status root)
    (invoke-status-key! "Z")
    (invoke-command-key! "g")
    (is= [linked] (:entries (iselect-state)))
    (select-current-iselect-entry!)
    (wait-for-focused-status linked "visit linked worktree")
    (cleanup linked root)))

(deftest regit-worktree-delete-current-linked-worktree-returns-to-primary-test
  (let [root (init-test-repo "regit-worktree-delete-current")
        linked (linked-worktree root "regit-worktree-delete-current-linked" "topic")]
    (status/regit-status linked)
    (invoke-status-key! "Z")
    (invoke-command-key! "k")
    (is= [linked] (:entries (iselect-state)))
    (select-current-iselect-entry!)
    (submit-simple-prompt! "y")
    (test/assert (not (path-exists? linked)) "current linked worktree should be removed")
    (wait-for-focused-status root "delete current linked worktree")
    (cleanup root)))

(deftest regit-worktree-move-current-linked-worktree-follows-new-path-test
  (let [root (init-test-repo "regit-worktree-move-current")
        linked (linked-worktree root "regit-worktree-move-current-linked" "topic")
        destination (temp-file-path "regit-worktree-move-current-destination")]
    (cleanup destination)
    (status/regit-status linked)
    (invoke-status-key! "Z")
    (invoke-command-key! "m")
    (select-current-iselect-entry!)
    (submit-simple-prompt! destination)
    (test/assert (not (path-exists? linked)) "old current worktree path should be gone")
    (wait-for-focused-status destination "move current linked worktree")
    (cleanup destination root)))
