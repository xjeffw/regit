(ns regit.tests.log
  (:require [regit.log :as log]
            [regit.tests.util :refer [buffer-content-lines sh!]]
            [relay.base.buffer :as buffer]
            [regit.preview :as regit-preview]
            [relay.string :as str]
            [relay.test :as test :refer [deftest is= is-error]]))

(deftest regit-log-interface-test
  (let [tmp-dir (temp-file-path "regit-log-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "first")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first commit"])
        _ (sh! "git" ["-C" tmp-dir "tag" "v0.1"])
        _ (sh! "git" ["-C" tmp-dir "branch" "feature"])
        _ (write-file file-path "second")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second commit"])
        _ (sh! "git" ["-C" tmp-dir "update-ref" "refs/remotes/origin/main" "HEAD"])
        seed-buffer (create-buffer)]
    (binding [*buffer* seed-buffer]
      (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
      (log/regit-log-current)
      (let [log-window (focused-window)
            log-buffer (window-buffer log-window)]
        (binding [*window* log-window
                  *buffer* log-buffer]
          (let [text (with-read-lock [lock (buffer-text log-buffer)]
                       (buffer/slice lock 0 (buffer/len-chars lock)))]
            (test/assert (str/index-of text "first commit") "regit-log missing first commit message")
            (test/assert (str/index-of text "second commit") "regit-log missing second commit message")
            (test/assert (str/index-of text "feature") "regit-log missing branch ref")
            (test/assert (str/index-of text "origin/main") "regit-log missing remote ref")
            (test/assert (str/index-of text "tag: v0.1") "regit-log missing tag ref"))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-log-target-test
  (let [tmp-dir (temp-file-path "regit-log-target-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "main")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "main commit"])
        _ (sh! "git" ["-C" tmp-dir "branch" "-M" "main"])
        _ (sh! "git" ["-C" tmp-dir "checkout" "-b" "remote-seed"])
        _ (write-file file-path "remote")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "remote commit"])
        _ (sh! "git" ["-C" tmp-dir "update-ref" "refs/remotes/origin/feature" "HEAD"])
        _ (sh! "git" ["-C" tmp-dir "checkout" "main"])
        seed-buffer (create-buffer)]
    (binding [*buffer* seed-buffer]
      (log/regit-log-target tmp-dir "origin/feature")
      (let [log-window (focused-window)
            log-buffer (window-buffer log-window)]
        (binding [*window* log-window
                  *buffer* log-buffer]
          (let [text (with-read-lock [lock (buffer-text log-buffer)]
                       (buffer/slice lock 0 (buffer/len-chars lock)))
                label (:label @(buffer-state log-buffer))]
            (test/assert (str/includes? text "Commits in origin/feature") "regit-log missing target header")
            (test/assert (str/includes? text "remote commit") "regit-log missing remote target commit")
            (test/assert (property-string? label) "regit-log label should preserve styled spans")
            (test/assert (str/includes? label "regit-log: ") "regit-log label missing prefix")
            (test/assert (str/includes? label "regit-log-target-test-repo") "regit-log label missing repo name")
            (test/assert (str/includes? label "origin/feature") "regit-log label missing branch target")))))
    (sh! "rm" ["-rf" tmp-dir])))

(deftest regit-log-preview-disabled-test
  (let [tmp-dir (temp-file-path "regit-log-preview-disabled-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "preview disabled\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "disabled log preview commit"])
        seed-buffer (create-buffer)
        previous-preview-on-focus regit-preview/regit-preview-on-focus]
    (delete-other-windows)
    (set! regit-preview/regit-preview-on-focus false)
    (try
      (binding [*buffer* seed-buffer]
        (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
        (log/regit-log-current)
        (let [log-window (focused-window)
              log-buffer (window-buffer log-window)]
          (binding [*window* log-window
                    *buffer* log-buffer]
            (let [lines (buffer-content-lines)
                  log/commit-line (some (fn [i] (when (str/includes? (nth lines i) "disabled log preview commit") i))
                                    (range (count lines)))]
              (test/assert log/commit-line "Could not find disabled log preview commit line")
              (move-cursor (with-read-lock [lock (buffer-text log-buffer)]
                             (buffer/line-to-char lock log/commit-line))
                false log-window)
              (sleep (ms->duration 100))
              (test/assert (not (regit-preview/active-preview log-buffer))
                "Log preview state was created while regit-preview-on-focus was false")
              (test/assert (not (some #(:regit-preview? @(buffer-state %)) (list-buffers)))
                "Log preview buffer was created while regit-preview-on-focus was false")))))
      (finally
        (set! regit-preview/regit-preview-on-focus previous-preview-on-focus)
        (sh! "rm" ["-rf" tmp-dir])))))

(deftest regit-log-previews-commit-and-promotes-on-enter-test
  (let [tmp-dir (temp-file-path "regit-log-preview-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "first\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first log preview commit"])
        _ (write-file file-path "second\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second log preview commit"])
        seed-buffer (create-buffer)]
    (delete-other-windows)
    (binding [*buffer* seed-buffer]
      (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
      (log/regit-log-current)
      (let [log-window (focused-window)
            log-buffer (window-buffer log-window)]
        (binding [*window* log-window
                  *buffer* log-buffer]
          (let [lines (buffer-content-lines)
                second-line (some (fn [i] (when (str/includes? (nth lines i) "second log preview commit") i))
                              (range (count lines)))
                first-line (some (fn [i] (when (str/includes? (nth lines i) "first log preview commit") i))
                             (range (count lines)))]
            (test/assert second-line "Could not find second commit line")
            (test/assert first-line "Could not find first commit line")
            (move-cursor (with-read-lock [lock (buffer-text log-buffer)]
                           (buffer/line-to-char lock first-line))
              false log-window)
            (let [first-target (log/preview-target tmp-dir (log/commit-id-at-line first-line))
                  first-preview (regit-preview/wait-for-preview-buffer log-buffer first-target 4000)]
              (test/assert first-preview "First commit preview buffer was not displayed")
              (is= log-window (focused-window))
              (let [first-preview-window (first (filter #(= (:id (window-buffer %)) (:id first-preview))
                                                  (frame-normal-windows)))]
                (test/assert first-preview-window "First commit preview window not found")
                (let [previous-hook regit-preview/*before-create-preview-buffer-hook*]
                  (set! regit-preview/*before-create-preview-buffer-hook*
                    (fn [] (sleep (ms->duration 150))))
                  (try
                    (move-cursor (with-read-lock [lock (buffer-text log-buffer)]
                                   (buffer/line-to-char lock second-line))
                      false log-window)
                    (test/assert (some #(= (:id %) (:id first-preview)) (list-buffers))
                      "First commit preview buffer was closed before the replacement preview was ready")
                    (is= first-preview (window-buffer first-preview-window))
                    (finally
                      (set! regit-preview/*before-create-preview-buffer-hook* previous-hook))))
                (let [second-target (log/preview-target tmp-dir (log/commit-id-at-line second-line))
                      preview-buffer (regit-preview/wait-for-preview-buffer log-buffer second-target 4000)]
                  (test/assert preview-buffer "Second commit preview buffer was not displayed")
                  (test/assert (regit-preview/wait-for-buffer-closed first-preview 500)
                    "First commit preview buffer was not closed after the second commit preview displayed")
                  (let [preview-window (first (filter #(= (:id (window-buffer %)) (:id preview-buffer))
                                                (frame-normal-windows)))]
                    (test/assert preview-window "Second commit preview window not found")
                    (test/assert (not= log-window preview-window) "Commit preview did not use another window")
                    (binding [*window* preview-window
                              *buffer* preview-buffer]
                      (is= :regit-view-commit *mode*)
                      (let [text (with-read-lock [lock (buffer-text preview-buffer)]
                                   (buffer/slice lock 0 (buffer/len-chars lock)))]
                        (test/assert (str/includes? text "second log preview commit")
                          (str "Commit preview missing second commit summary. Got: " text))))
                    (binding [*window* log-window
                              *buffer* log-buffer]
                      (log/regit-log-enter))
                    (is= preview-window (focused-window))
                    (is= preview-buffer (window-buffer preview-window))
                    (test/assert (not (regit-preview/active-preview log-buffer))
                      "Source log buffer still had active preview state after promotion")
                    (test/assert (str/includes? (:name preview-buffer) "*regit-commit: ")
                      (str "Promoted log preview kept preview name: " (:name preview-buffer)))
                    (set-focused-window log-window)
                    (move-cursor 0 false log-window)
                    (test/assert (some #(= (:id %) (:id preview-buffer)) (list-buffers))
                      "Promoted log preview buffer was killed after moving the log cursor"))))))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-log-kills-preview-that-loses-token-after-display-test
  (let [tmp-dir (temp-file-path "regit-log-preview-race-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "first\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first race preview commit"])
        _ (write-file file-path "second\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second race preview commit"])
        _ (write-file file-path "third\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "third race preview commit"])
        seed-buffer (create-buffer)
        raced-preview (atom nil)]
    (delete-other-windows)
    (binding [*buffer* seed-buffer]
      (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
      (log/regit-log-current)
      (let [log-window (focused-window)
            log-buffer (window-buffer log-window)]
        (binding [*window* log-window
                  *buffer* log-buffer]
          (let [lines (buffer-content-lines)
                first-line (some (fn [i] (when (str/includes? (nth lines i) "first race preview commit") i))
                             (range (count lines)))
                second-line (some (fn [i] (when (str/includes? (nth lines i) "second race preview commit") i))
                              (range (count lines)))
                third-line (some (fn [i] (when (str/includes? (nth lines i) "third race preview commit") i))
                             (range (count lines)))
                line-pos (fn [line]
                           (with-read-lock [lock (buffer-text log-buffer)]
                             (buffer/line-to-char lock line)))]
            (test/assert first-line "Could not find first commit line")
            (test/assert second-line "Could not find second commit line")
            (test/assert third-line "Could not find third commit line")
            (move-cursor (line-pos first-line) false log-window)
            (let [first-target (log/preview-target tmp-dir (log/commit-id-at-line first-line))
                  first-preview (regit-preview/wait-for-preview-buffer log-buffer first-target 4000)]
              (test/assert first-preview "First commit preview buffer was not displayed")
              (let [previous-hook regit-preview/*after-set-preview-buffer-hook*
                    third-target (log/preview-target tmp-dir (log/commit-id-at-line third-line))]
                (set! regit-preview/*after-set-preview-buffer-hook*
                  (fn [preview-buffer _preview-window]
                    (reset! raced-preview preview-buffer)
                    (set! regit-preview/*after-set-preview-buffer-hook* nil)
                    (move-cursor (line-pos third-line) false log-window)))
                (try
                  (move-cursor (line-pos second-line) false log-window)
                  (let [third-preview (regit-preview/wait-for-preview-buffer log-buffer third-target 4000)]
                    (test/assert third-preview "Third commit preview buffer was not displayed")
                    (test/assert @raced-preview "Race hook did not capture the losing preview buffer")
                    (sleep (ms->duration 100))
                    (test/assert (not (some #(= (:id %) (:id @raced-preview)) (list-buffers)))
                      "Preview buffer that lost ownership after display was retained")
                    (let [preview-buffers (filter #(:regit-preview? @(buffer-state %)) (list-buffers))]
                      (is= 1 (count preview-buffers))
                      (is= (:id third-preview) (:id (first preview-buffers)))))
                  (finally
                    (set! regit-preview/*after-set-preview-buffer-hook* previous-hook))))))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-log-cleans-registered-orphan-preview-buffers-test
  (let [tmp-dir (temp-file-path "regit-log-preview-orphan-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "first\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first orphan preview commit"])
        _ (write-file file-path "second\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second orphan preview commit"])
        seed-buffer (create-buffer)]
    (delete-other-windows)
    (binding [*buffer* seed-buffer]
      (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
      (log/regit-log-current)
      (let [log-window (focused-window)
            log-buffer (window-buffer log-window)]
        (binding [*window* log-window
                  *buffer* log-buffer]
          (let [lines (buffer-content-lines)
                first-line (some (fn [i] (when (str/includes? (nth lines i) "first orphan preview commit") i))
                             (range (count lines)))
                second-line (some (fn [i] (when (str/includes? (nth lines i) "second orphan preview commit") i))
                              (range (count lines)))
                line-pos (fn [line]
                           (with-read-lock [lock (buffer-text log-buffer)]
                             (buffer/line-to-char lock line)))]
            (test/assert first-line "Could not find first commit line")
            (test/assert second-line "Could not find second commit line")
            (move-cursor (line-pos first-line) false log-window)
            (let [first-target (log/preview-target tmp-dir (log/commit-id-at-line first-line))
                  first-preview (regit-preview/wait-for-preview-buffer log-buffer first-target 4000)]
              (test/assert first-preview "First commit preview buffer was not displayed")
              (let [orphan-token (gensym "regit-preview-orphan")
                    orphan-preview (call-var regit.view-commit/create-regit-view-commit-preview-buffer!
                                     tmp-dir
                                     (log/commit-id-at-line second-line)
                                     log-window
                                     (fn [buffer]
                                       (swap! (buffer-state buffer) assoc
                                         :regit-preview? true
                                         :regit-preview-token orphan-token
                                         :regit-preview-source-buffer log-buffer)))]
                (test/assert (some #(= (:id %) (:id orphan-preview)) (list-buffers))
                  "Orphan preview buffer was not created")
                (log/update-log-preview!)
                (sleep (ms->duration 100))
                (test/assert (not (some #(= (:id %) (:id orphan-preview)) (list-buffers)))
                  "Registered orphan preview buffer was retained")
                (test/assert (some #(= (:id %) (:id first-preview)) (list-buffers))
                  "Current preview buffer was removed while cleaning orphans")
                (is= (:id first-preview) (:id (:buffer (regit-preview/active-preview log-buffer)))))))))
      (sh! "rm" ["-rf" tmp-dir]))))

(deftest regit-log-coalesces-rapid-preview-updates-test
  (let [tmp-dir (temp-file-path "regit-log-preview-coalesce-test-repo")
        _ (sh! "rm" ["-rf" tmp-dir])
        _ (sh! "mkdir" [tmp-dir])
        _ (sh! "git" ["-C" tmp-dir "init"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.email" "regit@test.invalid"])
        _ (sh! "git" ["-C" tmp-dir "config" "user.name" "Regit Test"])
        file-path (path-join tmp-dir "test.txt")
        _ (write-file file-path "first\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "first coalesced preview commit"])
        _ (write-file file-path "second\n")
        _ (sh! "git" ["-C" tmp-dir "add" "test.txt"])
        _ (sh! "git" ["-C" tmp-dir "commit" "-m" "second coalesced preview commit"])
        seed-buffer (create-buffer)
        previous-delay regit-preview/regit-preview-delay-ms
        previous-hook regit-preview/*before-create-preview-buffer-hook*
        create-count (atom 0)]
    (delete-other-windows)
    (set! regit-preview/regit-preview-delay-ms 75)
    (set! regit-preview/*before-create-preview-buffer-hook*
      (fn [] (swap! create-count inc)))
    (try
      (binding [*buffer* seed-buffer]
        (swap! (buffer-state seed-buffer) assoc :regit-root tmp-dir)
        (log/regit-log-current)
        (let [log-window (focused-window)
              log-buffer (window-buffer log-window)]
          (binding [*window* log-window
                    *buffer* log-buffer]
            (let [lines (buffer-content-lines)
                  first-line (some (fn [i] (when (str/includes? (nth lines i) "first coalesced preview commit") i))
                               (range (count lines)))
                  second-line (some (fn [i] (when (str/includes? (nth lines i) "second coalesced preview commit") i))
                                (range (count lines)))
                  line-pos (fn [line]
                             (with-read-lock [lock (buffer-text log-buffer)]
                               (buffer/line-to-char lock line)))]
              (test/assert first-line "Could not find first commit line")
              (test/assert second-line "Could not find second commit line")
              (move-cursor (line-pos first-line) false log-window)
              (move-cursor (line-pos second-line) false log-window)
              (let [second-target (log/preview-target tmp-dir (log/commit-id-at-line second-line))
                    second-preview (regit-preview/wait-for-preview-buffer log-buffer second-target 4000)]
                (test/assert second-preview "Second commit preview buffer was not displayed")
                (is= 1 @create-count)
                (is= second-preview (:buffer (regit-preview/active-preview log-buffer))))))))
      (finally
        (set! regit-preview/regit-preview-delay-ms previous-delay)
        (set! regit-preview/*before-create-preview-buffer-hook* previous-hook)
        (sh! "rm" ["-rf" tmp-dir])))))
